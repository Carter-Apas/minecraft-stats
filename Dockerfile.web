FROM node:22-alpine AS deps
WORKDIR /app
COPY tsconfig.base.json ./
COPY web web
WORKDIR /app/web
RUN npm ci

FROM deps AS build
WORKDIR /app/web
RUN npm run build

FROM nginx:1.29-alpine AS runtime
COPY web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/web/dist /usr/share/nginx/html
EXPOSE 8080
